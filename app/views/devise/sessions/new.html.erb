<h2>Log in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="field">
    <%#= f.label :email, class:'tag' %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email", type:'email', placeholder:'Enter Email Address' %>
  </div>

  <div class="field">
    <%#= f.label :password, class:'tag' %><br />
    <%= f.password_field :password, autocomplete: "current-password", type:'password', placeholder:'Enter Password' %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="content field" style="display:flex;flex-direction:row wrap;gap:1em;">
      <%= f.label :remember_me, class:'tag is-info is-light' %>
      <%= f.check_box :remember_me, type:'checkbox' %>
    </div>
  <% end %>

  <div class="actions">
    <%= f.submit "Lets Go!", class: 'button is-secondary' %>
  </div>
<% end %>

<%#= render "devise/shared/links" %>
