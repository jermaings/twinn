<h2>Sign up</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email", type:'email', class:'input' %>
  </div>

  <div class="field">
    <%= f.label :password %>
    <% if @minimum_password_length %>
    <em>(<%= @minimum_password_length %> characters minimum)</em>
    <% end %><br />
    <%= f.password_field :password, autocomplete: "new-password", placeholder:'Enter Password' , type:'password', class:'input' %>
  </div>

  <div class="field">
    <%#= f.label :password_confirmation %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder:'Enter Password Confirmation',  type:'password', class:'input is-primary' %>
  </div>

 <div class="actions" style="display:flex;flex-direction:column;align-items:center;gap:1em;">
    <%= f.submit "Lets Go!", class:'button is-success', style:'max-width:fit-content;' %>
    <%#= render "devise/shared/links" %>
  </div>
<% end %>

