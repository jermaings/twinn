<div id="<%= dom_id order %>">
  
  <p>
    <strong>Name:</strong>
    <%= order.name %>
  </p>

  <p>
    <strong>Price:</strong>
    <%= order.price %>
  </p>

  <p>
    <strong>Tax:</strong>
    <%= order.tax %>
  </p>

  <p>
    <strong>Total:</strong>
    <%= order.total %>
  </p>

  <p>
    <strong>Ordernumber:</strong>
    <%= order.orderNumber %>
  </p>

</div>
