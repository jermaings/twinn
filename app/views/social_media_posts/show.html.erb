<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><%= link_to "Discussions", discussions_path %></li>
    <li class="breadcrumb-item"><%= link_to @discussion.title, @discussion %></li>
    <li class="breadcrumb-item"><%= link_to @topic.title, [@discussion, @topic] %></li>
    <li class="breadcrumb-item active" aria-current="page">Social Media Post</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Social Media Post</h1>
  <span class="badge bg-<%= @social_media_post.status == 'posted' ? 'success' : @social_media_post.status == 'pending' ? 'warning' : @social_media_post.status == 'failed' ? 'danger' : 'secondary' %> fs-6">
    <%= @social_media_post.status.titleize %>
  </span>
</div>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <div>
      <strong><%= @social_media_post.platform.titleize %></strong>
      <% if @social_media_post.posted_at %>
        <small class="text-muted">Posted <%= time_ago_in_words(@social_media_post.posted_at) %> ago</small>
      <% end %>
    </div>
    <% if @social_media_post.posted? && @social_media_post.platform_url %>
      <a href="<%= @social_media_post.platform_url %>" target="_blank" class="btn btn-sm btn-outline-primary">
        View on <%= @social_media_post.platform.titleize %>
      </a>
    <% end %>
  </div>
  <div class="card-body">
    <p class="card-text"><%= simple_format(@social_media_post.content) %></p>
  </div>
  <div class="card-footer">
    <div class="btn-group">
      <% unless @social_media_post.posted? %>
        <%= link_to "Edit", edit_discussion_topic_social_media_post_path(@discussion, @topic, @social_media_post), 
            class: "btn btn-outline-primary" %>
      <% end %>
      <%= link_to "Delete", [@discussion, @topic, @social_media_post], 
          method: :delete, 
          class: "btn btn-outline-danger", 
          confirm: "Are you sure?",
          data: { method: :delete } %>
      <%= link_to "Back to Topic", [@discussion, @topic], class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>
