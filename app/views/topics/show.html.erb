<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Discussions", discussions_path %></li>
        <li class="breadcrumb-item"><%= link_to @discussion.title, @discussion %></li>
        <li class="breadcrumb-item active" aria-current="page"><%= @topic.title %></li>
      </ol>
    </nav>
    <h1><%= @topic.title %></h1>
  </div>
  <div class="btn-group">
    <%= link_to "Edit", edit_discussion_topic_path(@discussion, @topic), class: "btn btn-outline-primary" %>
    <%= link_to "Back", @discussion, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <p class="card-text"><%= simple_format(@topic.description) %></p>
  </div>
</div>

<!-- Social Media Integration Section -->
<div class="row">
  <div class="col-md-8">
    <h2>Social Media Posts</h2>
    
    <% if @social_media_posts.any? %>
      <% @social_media_posts.each do |post| %>
        <div class="card mb-3">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <strong><%= post.platform.titleize %></strong>
              <span class="badge bg-<%= post.status == 'posted' ? 'success' : post.status == 'pending' ? 'warning' : post.status == 'failed' ? 'danger' : 'secondary' %>">
                <%= post.status.titleize %>
              </span>
            </div>
            <small class="text-muted">
              <%= post.posted_at ? "Posted #{time_ago_in_words(post.posted_at)} ago" : "Created #{time_ago_in_words(post.created_at)} ago" %>
            </small>
          </div>
          <div class="card-body">
            <p class="card-text"><%= simple_format(post.content) %></p>
            <% if post.posted? && post.platform_url %>
              <a href="<%= post.platform_url %>" target="_blank" class="btn btn-sm btn-outline-primary">
                View on <%= post.platform.titleize %>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="alert alert-info">
        <h4 class="alert-heading">No social media posts yet</h4>
        <p>Share this topic on social media platforms to engage your audience.</p>
      </div>
    <% end %>
  </div>
  
  <div class="col-md-4">
    <h3>Share on Social Media</h3>
    
    <% if @available_platforms.any? %>
      <div class="d-grid gap-2">
        <% @available_platforms.each do |platform| %>
          <%= button_to post_to_social_media_discussion_topic_path(@discussion, @topic, platform: platform), 
              method: :post, 
              class: "btn btn-outline-#{platform == 'twitter' ? 'info' : platform == 'facebook' ? 'primary' : platform == 'linkedin' ? 'success' : 'secondary'}" do %>
            <%= platform == 'twitter' ? '𝕏' : platform == 'facebook' ? 'f' : platform == 'linkedin' ? 'in' : '📷' %>
            Post to <%= platform.titleize %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-secondary">
        <small>This topic has been shared to all available platforms.</small>
      </div>
    <% end %>
    
    <div class="mt-3">
      <%= link_to "Manual Post", new_discussion_topic_social_media_post_path(@discussion, @topic), 
          class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>
