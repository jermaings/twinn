<div class="row justify-content-center">
  <div class="col-md-8">
    <h1>Edit Discussion</h1>

    <%= form_with model: @discussion, local: true, class: "row g-3" do |form| %>
      <% if @discussion.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@discussion.errors.count, "error") %> prohibited this discussion from being saved:</h4>
          <ul class="mb-0">
            <% @discussion.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="col-12">
        <%= form.label :title, class: "form-label" %>
        <%= form.text_field :title, class: "form-control" %>
      </div>

      <div class="col-12">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, rows: 5, class: "form-control" %>
      </div>

      <div class="col-12">
        <%= form.label :status, class: "form-label" %>
        <%= form.select :status, 
            options_for_select([['Draft', 'draft'], ['Active', 'active'], ['Archived', 'archived']], @discussion.status), 
            {}, { class: "form-select" } %>
      </div>

      <div class="col-12">
        <div class="btn-group">
          <%= form.submit "Update Discussion", class: "btn btn-primary" %>
          <%= link_to "Show", @discussion, class: "btn btn-outline-info" %>
          <%= link_to "Back", discussions_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
